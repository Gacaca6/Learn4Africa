# ==============================================================================
# Learn4Africa — Environment configuration (Convex + Next.js)
# ==============================================================================
# Copy to `.env.local` and fill in. Only `.env.example` is tracked —
# real `.env.local` / `.env.production` are gitignored.
# ==============================================================================

# ── Convex ───────────────────────────────────────────────────────────────────
# `npx convex dev` writes these into .env.local automatically the first
# time you run it. On Vercel, set them in the project settings (Production +
# Preview). The URL is public (access is gated per-function inside Convex).
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
CONVEX_DEPLOYMENT=YOUR-DEPLOYMENT

# ── App identity ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Learn4Africa
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate:  openssl rand -base64 32   (or `npx auth secret`)
AUTH_SECRET=replace-with-a-32-byte-random-base64-string
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create a client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod): https://YOUR-VERCEL-URL/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── AI providers (used by Convex actions in later stages) ────────────────────
# At least one of these is needed once we port the AI engines.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Image generation (optional — for comics, Stage 4) ────────────────────────
# HF_API_TOKEN=hf_...
