# ==============================================================================
# Learn4Africa — Example Environment Configuration
# ==============================================================================
# Copy to `.env.local` (frontend) and `backend/.env` (backend).
# Everything runs with local/free tools out of the box — the only secrets
# you actually need for a full demo are the Google OAuth ones.
#
# NEVER commit filled-in copies. `.env*` is gitignored; only this example
# file is tracked.
# ==============================================================================

# ── App (public — safe to ship in the bundle) ────────────────────────────────
NEXT_PUBLIC_APP_NAME=Learn4Africa
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Backend FastAPI default port is 8001 (see `npm run backend`).
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── NextAuth (frontend) ──────────────────────────────────────────────────────
# Generate:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-32-byte-random-base64-string
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create a client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# NextAuth v5 reads AUTH_GOOGLE_*; the backend reads GOOGLE_CLIENT_* for
# ID-token verification on /api/v1/auth/google. Keep both sets in sync.
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── MongoDB (backend user & progress store) ──────────────────────────────────
# Leave blank to run against the local JSON fallback at
# backend/data/local_users.json. The frontend will show a "Demo mode"
# banner in that state.
MONGODB_URI=
MONGODB_DB_NAME=learn4africa

# ── AI Provider (backend) ────────────────────────────────────────────────────
# Option 1: Ollama (FREE, runs locally). Default is the cloud-hosted
# minimax-m2; swap for a locally-pulled model like "llama3.1" for fully
# offline operation.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m2:cloud

# Option 2: OpenAI (paid)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here

# Option 3: Anthropic (paid)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Text-to-Speech (for podcasts) ────────────────────────────────────────────
TTS_PROVIDER=edge                 # free, no API key needed
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your-key-here

# ── Image Generation (for comics) ────────────────────────────────────────────
IMAGE_PROVIDER=huggingface
HF_API_TOKEN=hf_your-token-here
# IMAGE_PROVIDER=local
# SD_API_URL=http://localhost:7860

# ── Backend auth / security ──────────────────────────────────────────────────
# Generate:  openssl rand -hex 48
JWT_SECRET=replace-with-a-48-byte-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168              # 7 days for access tokens
REFRESH_EXPIRE_DAYS=30            # 30 days for refresh tokens

# Browser origins allowed to call the API. Comma-separated; NEVER "*".
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Optional: Postgres/Redis (legacy course flow only) ───────────────────────
# Leave blank — the auth/tracks path does not need either.
# DATABASE_URL=postgresql://zigama:zigama@localhost:5432/learn4africa
# REDIS_URL=redis://localhost:6379
