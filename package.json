{
  "name": "learn4africa",
  "version": "1.0.0",
  "description": "Free AI-powered learning platform for Africa — transforming any topic into multi-format courses with a personal AI tutor",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "convex": "convex dev",
    "dev:all": "concurrently -n next,convex -c blue,magenta \"npm run dev\" \"npm run convex\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "npm install"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-progress": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "convex": "^1.17.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^6.0.2"
  }
}
