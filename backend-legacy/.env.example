# Learn4Africa Backend Environment Variables
# Copy this file to .env and fill in your keys

# ── AI Provider ────────────────────────────────────────────
# Options: ollama (free, local) | openai | anthropic
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m2:cloud
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Text-to-Speech ─────────────────────────────────────────
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=

# ── Image Generation ───────────────────────────────────────
IMAGE_PROVIDER=huggingface
HF_API_TOKEN=
SD_API_URL=http://localhost:7860

# ── YouTube curriculum builder ─────────────────────────────
# No API key required. Uses youtube-search-python + yt-dlp.
# Just install: pip install youtube-search-python yt-dlp youtube-transcript-api

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://zigama:zigama@localhost:5432/learn4africa
REDIS_URL=redis://localhost:6379

# ── Security ───────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
CORS_ORIGINS=http://localhost:3000

# ── Google OAuth (ID token verification) ──────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── MongoDB (users, progress, portfolio, Mwalimu memory) ──
# Get a free cluster at https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/
MONGODB_DB_NAME=learn4africa
